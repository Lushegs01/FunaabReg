NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://scanmark:scanmark_dev_password@localhost:5432/scanmark
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-32-byte-random-secret
JWT_REFRESH_SECRET=replace-with-another-32-byte-random-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=scanmark-documents
S3_ACCESS_KEY_ID=scanmark
S3_SECRET_ACCESS_KEY=scanmark_dev_password
S3_FORCE_PATH_STYLE=true
MAX_UPLOAD_BYTES=10485760
